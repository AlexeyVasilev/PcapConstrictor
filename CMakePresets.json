{
    "version": 3,
    "configurePresets": [
        {
            "name": "ninja-debug",
            "displayName": "Ninja Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "ninja-release",
            "displayName": "Ninja Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "ninja-debug",
            "configurePreset": "ninja-debug"
        },
        {
            "name": "ninja-release",
            "configurePreset": "ninja-release"
        }
    ],
    "testPresets": [
        {
            "name": "ninja-debug",
            "configurePreset": "ninja-debug",
            "output": {
                "verbosity": "default"
            }
        },
        {
            "name": "ninja-release",
            "configurePreset": "ninja-release",
            "output": {
                "verbosity": "default"
            }
        }
    ]
}
